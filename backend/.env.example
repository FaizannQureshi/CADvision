# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=

# Optional: comma-separated browser origins allowed to call the API (for split frontend/API deploys)
# CORS_ORIGINS=https://your-app.pages.dev,http://localhost:5173

# Memory tuning (low-RAM hosts e.g. Render — defaults shown)
# CADVISION_MAX_IMAGE_SIDE=1600
# CADVISION_PDF_DPI=150
# CADVISION_CLIP_BATCH_SIZE=8
# CADVISION_ORB_MAX_FEATURES=2000
# CADVISION_TORCH_THREADS=2
